{
  "name": "ms-tile-server",
  "description": "Vector/Raster tile server for serving/caching xyz/wmts tiles",
  "version": "1.0.0",
  "license": "MIT",
  "author": "Huy Le <lqh23072000@gmail.com>",
  "keywords": [
    "ms-tile-server"
  ],
  "private": true,
  "type": "module",
  "main": "src/main.js",
  "bin": {
    "tile-server": "./entrypoint.sh"
  },
  "scripts": {
    "server": "./entrypoint.sh",
    "lint": "eslint \"src/**/*.{json,js,ts,tsx,css}\"",
    "format": "prettier --write \"src/**/*.{json,js,ts,tsx,css}\"",
    "upgrade": "npx npm-check-updates -u && npx json -I -f package.json -e \"if(this.dependencies){Object.keys(this.dependencies).forEach(k=>this.dependencies[k]=this.dependencies[k].replace(/^[~^]/,''))} if(this.devDependencies){Object.keys(this.devDependencies).forEach(k=>this.devDependencies[k]=this.devDependencies[k].replace(/^[~^]/,''))}\" && npm install",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{json,js,ts,tsx,css}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@maplibre/maplibre-gl-native": "6.3.0",
    "@maplibre/maplibre-gl-style-spec": "24.6.0",
    "@socket.io/cluster-adapter": "0.3.0",
    "@socket.io/sticky": "1.0.4",
    "ajv": "8.18.0",
    "archiver": "7.0.1",
    "axios": "1.13.5",
    "better-sqlite3": "12.6.2",
    "cache-manager": "7.2.8",
    "chokidar": "5.0.0",
    "cors": "2.8.6",
    "express": "5.2.1",
    "generic-pool": "3.9.0",
    "handlebars": "4.7.8",
    "http-status-codes": "2.3.0",
    "jspdf": "4.2.0",
    "mime": "4.1.0",
    "nanoid": "5.1.6",
    "node-cron": "4.2.1",
    "pg": "8.19.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "pmtiles": "4.4.0",
    "prom-client": "15.1.3",
    "protocol-buffers": "5.0.0",
    "sharp": "0.34.5",
    "socket.io": "4.8.3",
    "swagger-jsdoc": "6.2.8",
    "swagger-ui-express": "5.0.1"
  },
  "devDependencies": {
    "eslint": "10.0.2",
    "globals": "17.3.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "3.8.1"
  },
  "engines": {
    "node": ">=22 <=24"
  }
}